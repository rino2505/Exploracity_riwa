{
  "info": {
    "name": "Unit Testovi – Backend (UT-1 do UT-24)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "idOrganizatora", "value": "1" },
    { "key": "idPosjetitelja", "value": "1" },
    { "key": "idDogadaja", "value": "1" },
    { "key": "idPitanja", "value": "1" }
  ],
  "item": [
    {
      "name": "AUTH – Organizator",
      "item": [
        {
          "name": "UT-1 Login organizatora – uspješan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/loginorganizatora",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email_organizatora\": \"test@test.com\",\n  \"Lozinka_organizatora\": \"test123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[UT-1] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[UT-1] Tijelo sadrži ID_organizatora', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('ID_organizatora');",
                  "});",
                  "pm.test('[UT-1] Uloga je admin', () => {",
                  "  pm.expect(pm.response.json().uloga).to.eql('admin');",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('idOrganizatora', pm.response.json().ID_organizatora);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "UT-2 Login organizatora – krivi podaci",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/loginorganizatora",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email_organizatora\": \"nepostoji@test.com\",\n  \"Lozinka_organizatora\": \"kriva\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[UT-2] Status 401 za krive kredencijale', () => pm.response.to.have.status(401));",
                  "pm.test('[UT-2] Poruka Krivi login', () => {",
                  "  pm.expect(pm.response.text()).to.include('Krivi login');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
