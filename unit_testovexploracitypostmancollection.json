                  "pm.test('[UT-9] Response je array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('[UT-9] Elementi imaju ID_dogadaja i Naziv_dogadaja', () => {",
                  "  const data = pm.response.json();",
                  "  if (data.length > 0) {",
                  "    pm.expect(data[0]).to.have.property('ID_dogadaja');",
                  "    pm.expect(data[0]).to.have.property('Naziv_dogadaja');",
                  "    pm.collectionVariables.set('idDogadaja', data[0].ID_dogadaja);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "UT-10 Dohvat slike događaja – postoji",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dogadaj/{{idDogadaja}}/slika"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[UT-10] Status je 200 ili 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('[UT-10] Content-Type je image/jpeg', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('image');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
