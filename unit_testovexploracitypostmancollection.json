          "name": "UT-18 Admin – filter odgovorena pitanja",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/pitanja-filtrirano?idOrganizatora={{idOrganizatora}}&status=answered",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "pitanja-filtrirano"],
              "query": [
